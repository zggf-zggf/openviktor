# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://openviktor:openviktor_dev@localhost:5432/openviktor
POSTGRES_PASSWORD=openviktor_dev

# ─── Redis (optional for single-instance) ────────────────
REDIS_URL=redis://localhost:6379

# ─── Slack ───────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
# Enable Socket Mode and get an App-Level Token (xapp-...)
# Install to workspace and get Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# ─── LLM Providers ──────────────────────────────────────
# Required: at least one provider
ANTHROPIC_API_KEY=sk-ant-your-key

# Optional: fallback providers (Phase 8)
# OPENAI_API_KEY=sk-your-key
# GOOGLE_AI_API_KEY=your-key

# ─── Application ─────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
DEFAULT_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4096

# ─── Limits ──────────────────────────────────────────────
MAX_CONCURRENT_RUNS=16
TOOL_TIMEOUT_MS=600000
AGENT_TIMEOUT_MS=300000

# ─── Tool Backend ────────────────────────────────────────
# "local" (default) runs tools in-process; "modal" delegates to Modal.com
TOOL_BACKEND=local
# MODAL_ENDPOINT_URL=https://your-modal-app--execute.modal.run
# MODAL_AUTH_TOKEN=your-modal-auth-token

# ─── Cron Scheduler ─────────────────────────────────────
# How often to check for due cron jobs (ms). Default: 30000 (30s)
# CRON_CHECK_INTERVAL_MS=30000
# Enable/disable the heartbeat system. Default: true
# HEARTBEAT_ENABLED=true

# ─── Pipedream Connect (optional) ──────────────────────
# Sign up at https://pipedream.com/connect and create a project.
# All three must be set together to enable Pipedream integrations.
# PIPEDREAM_CLIENT_ID=your-client-id
# PIPEDREAM_CLIENT_SECRET=your-client-secret
# PIPEDREAM_PROJECT_ID=your-project-id
# PIPEDREAM_ENVIRONMENT=development

# ─── Permissions ────────────────────────────────────────
# Skip permission approval for Pipedream actions (NOT recommended for production)
# DANGEROUSLY_SKIP_PERMISSIONS=false
