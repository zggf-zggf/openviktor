{
	"name": "openviktor",
	"private": true,
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"test:coverage": "turbo run test:coverage",
		"db:generate": "bun run --filter @openviktor/db db:generate",
		"db:migrate": "bun run --filter @openviktor/db db:migrate",
		"db:studio": "bun run --filter @openviktor/db db:studio",
		"format": "biome format --write .",
		"clean": "turbo run clean"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "^1.3.10",
		"pino-pretty": "^13.1.3",
		"turbo": "^2.4.0",
		"typescript": "^5.8.0"
	},
	"packageManager": "bun@1.2.0",
	"engines": {
		"bun": ">=1.2.0"
	}
}
